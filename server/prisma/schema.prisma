generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserType {
  admin
  user
}

enum NotificationType {
  welcome
  urgent
}

enum DealType {
  buy
  jv
  financing
}

enum TerrainType {
  flat
  hilly
  mix
}

enum FeatureTag {
  road_access
  water
  electricity
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model User {
  id                String                 @id @default(uuid())
  
  // Better Auth fields
  email             String                 @unique
  name              String?
  image             String?
  emailVerified     Boolean                @default(false)
  
  // Custom business fields
  phone             String?
  userType          UserType               @default(user)
  profileMediaId    String?

  profileMedia      Media?                 @relation("UserProfileMedia", fields: [profileMediaId], references: [id])
  media             Media[]                @relation("UserMedia")

  individuals       Individual?
  companies         Company?
  koperasi          Koperasi?

  notifications     Notification[]
  notificationPrefs NotificationPreference?

  entityTypes       UserEntityType[]

  properties        Property[]
  enquiries         PropertyEnquiry[]

  sentMessages      Message[]              @relation("Sender")
  receivedMessages  Message[]              @relation("Receiver")

  shortlistFolders  ShortlistFolder[]

  // Better Auth relations
  accounts          Account[]
  sessions          Session[]

  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
}

//////////////////////////////////////////////////////
// BETTER AUTH
//////////////////////////////////////////////////////

model Account {
  id                String                 @id @default(uuid())
  userId            String                 // Changed to String
  accountId         String
  providerId        String
  password          String?                // Required for emailAndPassword authentication (hashed by Better Auth)
  accessToken       String?
  refreshToken      String?
  idToken           String?
  expiresAt         DateTime?

  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@unique([userId, providerId, accountId])
  @@index([userId])
}

model Session {
  id                String                 @id @default(uuid())
  userId            String                 // Changed to String
  token             String                 @unique
  expiresAt         DateTime
  ipAddress         String?
  userAgent         String?

  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([userId])
}

model Verification {
  id                String                 @id @default(uuid())
  identifier        String
  value             String
  expiresAt         DateTime
  token             String                 @unique

  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@unique([identifier, token])
}

//////////////////////////////////////////////////////
// USER TYPES DETAILS
//////////////////////////////////////////////////////

model Individual {
  id         String   @id @default(uuid())
  userId     String   @unique             // Changed to String
  fullName   String
  identityNo String?

  user       User     @relation(fields: [userId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Company {
  id             String   @id @default(uuid())
  userId         String   @unique             // Changed to String
  companyName    String
  registrationNo String?

  user           User     @relation(fields: [userId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Koperasi {
  id             String   @id @default(uuid())
  userId         String   @unique             // Changed to String
  koperasiName   String
  registrationNo String?

  user           User     @relation(fields: [userId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

//////////////////////////////////////////////////////
// ENTITY TYPES
//////////////////////////////////////////////////////

model EntityType {
  id        String           @id @default(uuid())
  name      String

  users     UserEntityType[]

  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model UserEntityType {
  id           String     @id @default(uuid())
  userId       String     // Changed to String
  entityTypeId String     // Changed to String

  user         User       @relation(fields: [userId], references: [id])
  entityType   EntityType @relation(fields: [entityTypeId], references: [id])

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, entityTypeId])
}

//////////////////////////////////////////////////////
// MEDIA
//////////////////////////////////////////////////////

model Media {
  id            String     @id @default(uuid())
  userId        String     // Changed to String
  fileUrl       String
  mediaType     String
  mediaCategory String

  user          User       @relation("UserMedia", fields: [userId], references: [id])
  profileUsers  User[]     @relation("UserProfileMedia")

  properties    Property[] 
  documents     Document[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([userId])
}

model Document {
  id                 String    @id @default(uuid())
  mediaId            String    // Changed to String
  verificationStatus String
  verifiedBy         String?   // Changed to String
  verifiedAt         DateTime?

  media              Media     @relation(fields: [mediaId], references: [id])

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

//////////////////////////////////////////////////////
// NOTIFICATIONS
//////////////////////////////////////////////////////

model NotificationPreference {
  id           String   @id @default(uuid())
  userId       String   @unique // Changed to String
  emailEnabled Boolean  @default(true)
  pushEnabled  Boolean  @default(true)

  user         User     @relation(fields: [userId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           // Changed to String
  type      NotificationType
  content   String
  isRead    Boolean          @default(false)

  user      User             @relation(fields: [userId], references: [id])

  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId])
}

//////////////////////////////////////////////////////
// PROPERTY CORE
//////////////////////////////////////////////////////

model Property {
  id                   String            @id @default(uuid())
  userId               String            // Changed to String
  title                String
  categoryId           String            // Changed to String
  ownershipTypeId      String            // Changed to String
  utilizationId        String            // Changed to String
  titleTypeId          String            // Changed to String
  landMediaId          String?           // Changed to String

  tanahRizabMelayu     Boolean?

  dealTypes            DealType[]
  terrainChips         TerrainType[]
  featureTags          FeatureTag[]

  landArea             Decimal           @db.Decimal(12,2)
  landAreaUnit         String

  estimatedValuation   Decimal?          @db.Decimal(12,2)

  description          String?
  listingCode          String            @unique

  price                Decimal           @db.Decimal(12,2)
  pricePerSqrft        Decimal           @db.Decimal(12,2)

  status               String?

  viewsCount           Int               @default(0)
  clicksCount          Int               @default(0)

  agreementAccepted    Boolean           @default(false)
  agreementAcceptedAt  DateTime?

  user                 User              @relation(fields: [userId], references: [id])
  media                Media?            @relation(fields: [landMediaId], references: [id])

  category             PropertyCategory  @relation(fields: [categoryId], references: [id])
  ownershipType        PropertyOwnershipType @relation(fields: [ownershipTypeId], references: [id])
  utilization          Utilization       @relation(fields: [utilizationId], references: [id])
  titleType            LandTitleType     @relation(fields: [titleTypeId], references: [id])

  leaseholdDetails     LeaseholdDetail?
  location             Location?

  enquiries            PropertyEnquiry[]
  shortlistedBy        ShortlistProperty[]

  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([userId])
}

//////////////////////////////////////////////////////
// PROPERTY SUPPORT
//////////////////////////////////////////////////////

model LeaseholdDetail {
  id               String   @id @default(uuid())
  propertyId       String   @unique // Changed to String
  startYear        Int
  leasePeriodYears Int

  property         Property @relation(fields: [propertyId], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Location {
  id            String   @id @default(uuid())
  propertyId    String   @unique // Changed to String
  state         String
  district      String
  mukim         String?
  section       String?

  latitude      Decimal  @db.Decimal(11,8)
  longitude     Decimal  @db.Decimal(11,8)

  isApproximate Boolean  @default(false)

  property      Property @relation(fields: [propertyId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

//////////////////////////////////////////////////////
// LOOKUP TABLES
//////////////////////////////////////////////////////

model PropertyCategory {
  id         String     @id @default(uuid())
  name       String

  properties Property[]

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model PropertyOwnershipType {
  id         String     @id @default(uuid())
  name       String

  properties Property[]

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Utilization {
  id         String     @id @default(uuid())
  name       String

  properties Property[]

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model LandTitleType {
  id         String     @id @default(uuid())
  name       String

  properties Property[]

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

//////////////////////////////////////////////////////
// ENQUIRIES & MESSAGING
//////////////////////////////////////////////////////

model InterestType {
  id        String            @id @default(uuid())
  name      String

  enquiries PropertyEnquiry[]

  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model PropertyEnquiry {
  id             String        @id @default(uuid())
  propertyId     String        // Changed to String
  userId         String        // Changed to String
  interestTypeId String        // Changed to String

  message        String?
  budget         Decimal?      @db.Decimal(12,2)
  timeline       String?
  status         String?

  property       Property      @relation(fields: [propertyId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
  interestType   InterestType  @relation(fields: [interestTypeId], references: [id])

  roles          EnquiryRole[]
  messages       Message[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId])
  @@index([propertyId])
}

model Role {
  id           String        @id @default(uuid())
  name         String

  enquiryRoles EnquiryRole[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model EnquiryRole {
  id        String          @id @default(uuid())
  enquiryId String          // Changed to String
  roleId    String          // Changed to String

  enquiry   PropertyEnquiry @relation(fields: [enquiryId], references: [id])
  role      Role            @relation(fields: [roleId], references: [id])

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([enquiryId, roleId])
}

model Message {
  id         String          @id @default(uuid())
  senderId   String          // Changed to String
  receiverId String          // Changed to String
  enquiryId  String          // Changed to String

  content    String

  sender     User            @relation("Sender", fields: [senderId], references: [id])
  receiver   User            @relation("Receiver", fields: [receiverId], references: [id])
  enquiry    PropertyEnquiry @relation(fields: [enquiryId], references: [id])

  createdAt  DateTime        @default(now())

  @@index([senderId])
  @@index([receiverId])
}

//////////////////////////////////////////////////////
// SHORTLIST
//////////////////////////////////////////////////////

model ShortlistFolder {
  id              String              @id @default(uuid())
  userId          String              // Changed to String
  name            String
  parentFolderId  String?             // Parent folder for nested structure
  
  user            User                @relation(fields: [userId], references: [id])
  parentFolder    ShortlistFolder?    @relation("SubFolders", fields: [parentFolderId], references: [id], onDelete: Cascade)
  subFolders      ShortlistFolder[]   @relation("SubFolders")
  properties      ShortlistProperty[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  @@index([userId])
  @@index([parentFolderId])
}

model ShortlistProperty {
  id         String          @id @default(uuid())
  folderId   String          // Changed to String
  propertyId String          // Changed to String

  folder     ShortlistFolder @relation(fields: [folderId], references: [id])
  property   Property        @relation(fields: [propertyId], references: [id])

  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([folderId, propertyId])
}