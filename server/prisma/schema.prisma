generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String                  @id @default(uuid())
  email             String                  @unique
  phone             String?
  userType          UserType                @default(user)
  profileMediaId    String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  name              String?
  image             String?
  emailVerified     Boolean                 @default(false)
  status            UserStatus              @default(active)
  accounts          Account[]
  companies         Company?
  individuals       Individual?
  koperasi          Koperasi?
  media             Media[]                 @relation("UserMedia")
  receivedMessages  Message[]               @relation("Receiver")
  sentMessages      Message[]               @relation("Sender")
  notifications     Notification[]
  notificationPrefs NotificationPreference?
  properties        Property[]
  enquiries         PropertyEnquiry[]
  sessions          Session[]
  shortlistFolders  ShortlistFolder[]
  profileMedia      Media?                  @relation("UserProfileMedia", fields: [profileMediaId], references: [id])
  entityTypes       UserEntityType[]
}

model Account {
  id           String    @id @default(uuid())
  userId       String
  accountId    String
  providerId   String
  accessToken  String?
  refreshToken String?
  idToken      String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  password     String?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId, accountId])
  @@index([userId])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  token      String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, token])
}

model Individual {
  id         String   @id @default(uuid())
  userId     String   @unique
  fullName   String
  identityNo String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Company {
  id             String   @id @default(uuid())
  userId         String   @unique
  companyName    String
  registrationNo String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Koperasi {
  id             String   @id @default(uuid())
  userId         String   @unique
  koperasiName   String
  registrationNo String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EntityType {
  id        String           @id @default(uuid())
  name      String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  users     UserEntityType[]
}

model UserEntityType {
  id           String     @id @default(uuid())
  userId       String
  entityTypeId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  entityType   EntityType @relation(fields: [entityTypeId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entityTypeId])
}

model Media {
  id            String     @id @default(uuid())
  userId        String
  fileUrl       String
  mediaType     String
  mediaCategory String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  propertyId    String?
  documents     Document[]
  property      Property?  @relation("PropertyMedia", fields: [propertyId], references: [id], onDelete: Cascade)
  user          User       @relation("UserMedia", fields: [userId], references: [id], onDelete: Cascade)
  profileUsers  User[]     @relation("UserProfileMedia")

  @@index([userId])
  @@index([propertyId])
}

model Document {
  id                 String    @id @default(uuid())
  mediaId            String
  verificationStatus String
  verifiedBy         String?
  verifiedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  propertyId         String?
  media              Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  property           Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model NotificationPreference {
  id           String   @id @default(uuid())
  userId       String   @unique
  emailEnabled Boolean  @default(true)
  pushEnabled  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  content   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Property {
  id                  String                @id @default(uuid())
  userId              String
  title               String
  categoryId          String
  ownershipTypeId     String
  utilizationId       String
  titleTypeId         String
  landMediaId         String?
  tanahRizabMelayu    Boolean?
  adminAction         String?
  dealTypes           DealType[]
  terrainChips        TerrainType[]
  featureTags         FeatureTag[]
  landArea            Decimal               @db.Decimal(12, 2)
  landAreaUnit        String
  estimatedValuation  Decimal?              @db.Decimal(12, 2)
  description         String?
  listingCode         String                @unique
  price               Decimal               @db.Decimal(12, 2)
  pricePerSqrft       Decimal               @db.Decimal(12, 2)
  viewsCount          Int                   @default(0)
  clicksCount         Int                   @default(0)
  agreementAccepted   Boolean               @default(false)
  agreementAcceptedAt DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  status              PropertyStatus?
  documents           Document[]
  leaseholdDetails    LeaseholdDetail?
  location            Location?
  media               Media[]               @relation("PropertyMedia")
  category            PropertyCategory      @relation(fields: [categoryId], references: [id])
  ownershipType       PropertyOwnershipType @relation(fields: [ownershipTypeId], references: [id])
  titleType           LandTitleType         @relation(fields: [titleTypeId], references: [id])
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  utilization         Utilization           @relation(fields: [utilizationId], references: [id])
  enquiries           PropertyEnquiry[]
  shortlistedBy       ShortlistProperty[]

  @@index([userId])
}

model LeaseholdDetail {
  id               String   @id @default(uuid())
  propertyId       String   @unique
  startYear        Int
  leasePeriodYears Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  property         Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Location {
  id            String   @id @default(uuid())
  propertyId    String   @unique
  state         String
  district      String
  mukim         String?
  section       String?
  latitude      Decimal  @db.Decimal(11, 8)
  longitude     Decimal  @db.Decimal(11, 8)
  isApproximate Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model PropertyCategory {
  id         String     @id @default(uuid())
  name       String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  properties Property[]
}

model PropertyOwnershipType {
  id         String     @id @default(uuid())
  name       String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  properties Property[]
}

model Utilization {
  id         String     @id @default(uuid())
  name       String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  properties Property[]
}

model LandTitleType {
  id         String     @id @default(uuid())
  name       String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  properties Property[]
}

model InterestType {
  id        String            @id @default(uuid())
  name      String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  enquiries PropertyEnquiry[]
}

model PropertyEnquiry {
  id             String         @id @default(uuid())
  propertyId     String
  userId         String
  interestTypeId String
  message        String?
  budget         Decimal?       @db.Decimal(12, 2)
  timeline       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  status         enquiryStatus? @default(PENDING_MATCHING)
  roles          EnquiryRole[]
  messages       Message[]
  interestType   InterestType   @relation(fields: [interestTypeId], references: [id])
  property       Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([propertyId])
}

model Role {
  id           String        @id @default(uuid())
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  enquiryRoles EnquiryRole[]
}

model EnquiryRole {
  id        String          @id @default(uuid())
  enquiryId String
  roleId    String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  enquiry   PropertyEnquiry @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  role      Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([enquiryId, roleId])
}

model Message {
  id         String          @id @default(uuid())
  senderId   String
  receiverId String
  enquiryId  String
  content    String
  createdAt  DateTime        @default(now())
  enquiry    PropertyEnquiry @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  receiver   User            @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User            @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
}

model ShortlistFolder {
  id             String              @id @default(uuid())
  userId         String
  name           String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  parentFolderId String?
  parentFolder   ShortlistFolder?    @relation("SubFolders", fields: [parentFolderId], references: [id], onDelete: Cascade)
  subFolders     ShortlistFolder[]   @relation("SubFolders")
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  properties     ShortlistProperty[]

  @@index([userId])
  @@index([parentFolderId])
}

model ShortlistProperty {
  id         String          @id @default(uuid())
  folderId   String
  propertyId String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  folder     ShortlistFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  property   Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([folderId, propertyId])
}

enum UserType {
  admin
  user
  superadmin
}

enum UserStatus {
  active
  suspended
}

enum NotificationType {
  welcome
  urgent
}

enum DealType {
  buy
  jv
  financing
}

enum TerrainType {
  flat
  hilly
  mix
}

enum FeatureTag {
  road_access
  water
  electricity
}

enum PropertyStatus {
  draft
  active
  pending
  under_review   @map("under review")
  need_more_info @map("need more info")
  rejected
  deleted
}

enum enquiryStatus {
  SCHEDULED
  MATCHED_INPROGRESS
  PENDING_MATCHING
  UNDER_REVIEW
  NEED_MORE_INFO
  CLOSED_NOT_PROCEEDING
  CLOSED_SUCCESSFUL
}
