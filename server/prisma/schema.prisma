generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserType {
  admin
  user
}

enum NotificationType {
  welcome
  urgent
}

enum DealType {
  buy
  jv
  financing
}

enum TerrainType {
  flat
  hilly
  mix
}

enum FeatureTag {
  road_access
  water
  electricity
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model User {
  id                 Int                    @id @default(autoincrement())
  clerkId            String                 @unique // Added this line
  email              String                 @unique
  phone              String?
  userType           UserType
  profileMediaId     Int?
  
  profileMedia       Media?                 @relation("UserProfileMedia", fields: [profileMediaId], references: [id])
  media              Media[]                @relation("UserMedia")

  individuals        Individual?
  companies          Company?
  koperasi           Koperasi?

  notifications      Notification[]
  notificationPrefs  NotificationPreference?

  entityTypes        UserEntityType[]

  properties         Property[]
  enquiries          PropertyEnquiry[]

  sentMessages       Message[]              @relation("Sender")
  receivedMessages   Message[]              @relation("Receiver")

  shortlistFolders   ShortlistFolder[]

  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
}

//////////////////////////////////////////////////////
// USER TYPES DETAILS
//////////////////////////////////////////////////////

model Individual {
  id          Int    @id @default(autoincrement())
  userId      Int    @unique
  fullName    String
  identityNo  String?

  user        User   @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Company {
  id               Int    @id @default(autoincrement())
  userId           Int    @unique
  companyName      String
  registrationNo   String?

  user             User   @relation(fields: [userId], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Koperasi {
  id               Int    @id @default(autoincrement())
  userId           Int    @unique
  koperasiName     String
  registrationNo   String?

  user             User   @relation(fields: [userId], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

//////////////////////////////////////////////////////
// ENTITY TYPES
//////////////////////////////////////////////////////

model EntityType {
  id        Int    @id @default(autoincrement())
  name      String

  users     UserEntityType[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserEntityType {
  id            Int        @id @default(autoincrement())
  userId        Int
  entityTypeId  Int

  user          User       @relation(fields: [userId], references: [id])
  entityType    EntityType @relation(fields: [entityTypeId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, entityTypeId])
}

//////////////////////////////////////////////////////
// MEDIA
//////////////////////////////////////////////////////

model Media {
  id             Int      @id @default(autoincrement())
  userId         Int
  fileUrl        String
  mediaType      String
  mediaCategory  String

  user           User     @relation("UserMedia", fields: [userId], references: [id])
  profileUsers   User[]   @relation("UserProfileMedia")

  // --- ADD THIS LINE ---
  properties     Property[] 
  // ----------------------

  documents      Document[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model Document {
  id                 Int      @id @default(autoincrement())
  mediaId            Int
  verificationStatus String
  verifiedBy         Int?
  verifiedAt         DateTime?

  media              Media    @relation(fields: [mediaId], references: [id])

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

//////////////////////////////////////////////////////
// NOTIFICATIONS
//////////////////////////////////////////////////////

model NotificationPreference {
  id           Int     @id @default(autoincrement())
  userId       Int     @unique
  emailEnabled Boolean @default(true)
  pushEnabled  Boolean @default(true)

  user         User    @relation(fields: [userId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  content   String
  isRead    Boolean          @default(false)

  user      User             @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

//////////////////////////////////////////////////////
// PROPERTY CORE
//////////////////////////////////////////////////////

model Property {
  id                    Int            @id @default(autoincrement())
  userId                Int
  title                 String
  categoryId            Int
  ownershipTypeId       Int
  utilizationId         Int
  titleTypeId           Int
  landMediaId           Int?

  tanahRizabMelayu      Boolean?

  dealTypes             DealType[]     // ✅ ENUM ARRAY
  terrainChips          TerrainType[]  // ✅ ENUM ARRAY
  featureTags           FeatureTag[]   // ✅ ENUM ARRAY

  landArea              Decimal        @db.Decimal(12,2)
  landAreaUnit          String

  estimatedValuation    Decimal?       @db.Decimal(12,2)

  description           String?
  listingCode           String         @unique

  price                 Decimal        @db.Decimal(12,2)
  pricePerSqrft         Decimal        @db.Decimal(12,2)

  status                String?

  viewsCount            Int            @default(0)
  clicksCount           Int            @default(0)

  agreementAccepted     Boolean        @default(false)
  agreementAcceptedAt   DateTime?

  user                  User           @relation(fields: [userId], references: [id])
  media                 Media?         @relation(fields: [landMediaId], references: [id])

  category              PropertyCategory        @relation(fields: [categoryId], references: [id])
  ownershipType         PropertyOwnershipType   @relation(fields: [ownershipTypeId], references: [id])
  utilization           Utilization             @relation(fields: [utilizationId], references: [id])
  titleType             LandTitleType           @relation(fields: [titleTypeId], references: [id])

  leaseholdDetails      LeaseholdDetail?
  location              Location?

  enquiries             PropertyEnquiry[]
  shortlistedBy         ShortlistProperty[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
}

//////////////////////////////////////////////////////
// PROPERTY SUPPORT
//////////////////////////////////////////////////////

model LeaseholdDetail {
  id               Int      @id @default(autoincrement())
  propertyId       Int      @unique
  startYear        Int
  leasePeriodYears Int

  property         Property @relation(fields: [propertyId], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Location {
  id             Int      @id @default(autoincrement())
  propertyId     Int      @unique
  state          String
  district       String
  mukim          String?
  section        String?

  latitude       Decimal  @db.Decimal(10,8)
  longitude      Decimal  @db.Decimal(10,8)

  isApproximate  Boolean  @default(false)

  property       Property @relation(fields: [propertyId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

//////////////////////////////////////////////////////
// LOOKUP TABLES
//////////////////////////////////////////////////////

model PropertyCategory {
  id        Int        @id @default(autoincrement())
  name      String

  properties Property[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PropertyOwnershipType {
  id        Int        @id @default(autoincrement())
  name      String

  properties Property[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Utilization {
  id        Int        @id @default(autoincrement())
  name      String

  properties Property[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LandTitleType {
  id        Int        @id @default(autoincrement())
  name      String

  properties Property[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// ENQUIRIES & MESSAGING
//////////////////////////////////////////////////////

model InterestType {
  id        Int      @id @default(autoincrement())
  name      String

  enquiries PropertyEnquiry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PropertyEnquiry {
  id              Int      @id @default(autoincrement())
  propertyId      Int
  userId          Int
  interestTypeId  Int

  message         String?
  budget          Decimal? @db.Decimal(12,2)
  timeline        String?
  status          String?

  property        Property @relation(fields: [propertyId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
  interestType    InterestType @relation(fields: [interestTypeId], references: [id])

  roles           EnquiryRole[]
  messages        Message[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([propertyId])
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String

  enquiryRoles EnquiryRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EnquiryRole {
  id        Int      @id @default(autoincrement())
  enquiryId Int
  roleId    Int

  enquiry   PropertyEnquiry @relation(fields: [enquiryId], references: [id])
  role      Role            @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([enquiryId, roleId])
}

model Message {
  id          Int      @id @default(autoincrement())
  senderId    Int
  receiverId  Int
  enquiryId   Int

  content     String

  sender      User @relation("Sender", fields: [senderId], references: [id])
  receiver    User @relation("Receiver", fields: [receiverId], references: [id])
  enquiry     PropertyEnquiry @relation(fields: [enquiryId], references: [id])

  createdAt   DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
}

//////////////////////////////////////////////////////
// SHORTLIST
//////////////////////////////////////////////////////

model ShortlistFolder {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String

  user      User     @relation(fields: [userId], references: [id])
  properties ShortlistProperty[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShortlistProperty {
  id         Int      @id @default(autoincrement())
  folderId   Int
  propertyId Int

  folder     ShortlistFolder @relation(fields: [folderId], references: [id])
  property   Property        @relation(fields: [propertyId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([folderId, propertyId])
}